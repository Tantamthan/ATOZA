
@{
    ViewBag.Title = "LayoutExam";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/exam.css" />
</head>
<body>

    <div class="exam-header">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-light btn-sm border-0"><i class="fa-solid fa-arrow-left"></i></button>
            <div class="exam-title" title="@Model.Title">@Model.Title</div>
        </div>
        <div class="timer-badge" id="timerBox">
            <i class="fa-regular fa-clock"></i><span id="countdown" class="ms-2">--:--</span>
        </div>
        <button class="btn btn-primary-custom px-4 fw-bold shadow-sm" onclick="confirmSubmit()">Nộp bài</button>
    </div>
    @RenderBody()
    </body>
        </html>
