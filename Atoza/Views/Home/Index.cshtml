@{
    ViewData["Title"] = "Nền tảng tạo đề thi & bài tập online";
}

<!-- ========== HERO ========== -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="hero-badge">
                    <i class="fa-solid fa-star" style="font-size:0.7rem;"></i>
                    Phiên bản 2.0 — Chấm bài bằng AI
                </div>

                <h1 class="hero-title">
                    Nền tảng tạo đề thi,<br>
                    <span>bài tập online</span><br>
                    thông minh nhất
                </h1>

                <p class="hero-desc">
                    Giúp giáo viên tiết kiệm 90% thời gian chấm bài. Số hóa đề thi từ file Word/PDF chỉ trong 1 phút. Hỗ trợ trộn đề và chấm bài tự động.
                </p>

                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Account" asp-action="Register"
                       class="btn btn-orange btn-lg rounded-pill px-5 shadow-orange">
                        <i class="fa-solid fa-rocket me-2"></i>Dùng thử miễn phí
                    </a>
                    <a href="#features" class="btn btn-lg rounded-pill px-4"
                       style="border:2px solid var(--border);color:var(--text);font-weight:600;">
                        Xem tính năng <i class="fa-solid fa-arrow-down ms-1" style="font-size:0.8rem;"></i>
                    </a>
                </div>

                <div class="hero-stats">
                    <div>
                        <div class="hero-stat-number">1M+</div>
                        <div class="hero-stat-label">Học sinh sử dụng</div>
                    </div>
                    <div>
                        <div class="hero-stat-number">50k+</div>
                        <div class="hero-stat-label">Giáo viên tin dùng</div>
                    </div>
                    <div>
                        <div class="hero-stat-number">99%</div>
                        <div class="hero-stat-label">Độ hài lòng</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 offset-lg-1">
                <div class="upload-box" onclick="document.getElementById('fileInput').click()">
                    <div class="upload-icon">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                    </div>
                    <h4 class="fw-bold mb-1" style="color:var(--dark);">Tải lên đề thi ngay</h4>
                    <p class="text-muted small mb-4">Hỗ trợ .docx &bull; .pdf &bull; .xlsx</p>

                    <button class="btn btn-orange rounded-pill px-5 py-2" onclick="event.stopPropagation()">
                        <i class="fa-solid fa-folder-open me-2"></i>Chọn file
                    </button>

                    <p class="text-muted mt-3 mb-0" style="font-size:0.82rem;">
                        <i class="fa-solid fa-hand me-1"></i> hoặc kéo & thả file vào đây
                    </p>
                    <input type="file" id="fileInput" style="display:none;" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== TRUSTED LOGOS ========== -->
<div class="py-4 border-bottom border-top" style="background:#fff;">
    <div class="container">
        <div class="d-flex align-items-center justify-content-center gap-2 flex-wrap text-muted" style="font-size:0.85rem;">
            <span class="fw-600" style="font-weight:600;">Được tin dùng bởi:</span>
            @foreach (var school in new[]{ "Trường THPT Lê Hồng Phong", "THPT Chu Văn An", "THPT Nguyễn Thị Minh Khai", "Đại học Bách Khoa HN" })
            {
                <span class="badge rounded-pill px-3 py-2" style="background:var(--bg-light);color:var(--text);font-weight:500;border:1px solid var(--border);">@school</span>
            }
        </div>
    </div>
</div>



<!-- ========== CTA ========== -->
<section class="pb-5">
    <div class="container">
        <div class="text-center p-5 rounded-xl" style="background:var(--gradient-soft);border:1px solid rgba(255,106,0,0.15);">
            <h2 class="section-title mb-2">Sẵn sàng bắt đầu?</h2>
            <p class="text-muted mb-4">Đăng ký miễn phí ngay hôm nay và trải nghiệm sự khác biệt.</p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Account" asp-action="Register" class="btn btn-orange btn-lg rounded-pill px-5 shadow-orange">
                    <i class="fa-solid fa-rocket me-2"></i>Đăng ký miễn phí
                </a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-lg rounded-pill px-5"
                   style="border:2px solid var(--primary);color:var(--primary);font-weight:600;">
                    Đăng nhập
                </a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.getElementById('fileInput').addEventListener('change', function () {
            if (this.files.length > 0) {
                if (confirm('Bạn cần đăng nhập để xử lý file: ' + this.files[0].name + '. Đến trang đăng nhập ngay?')) {
                    window.location.href = '/Account/Login';
                }
            }
        });
        document.querySelectorAll('a[href^="#"]').forEach(a => {
            a.addEventListener('click', e => {
                const target = document.querySelector(a.getAttribute('href'));
                if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
            });
        });
    </script>
}
