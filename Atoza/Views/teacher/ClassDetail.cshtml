@model ATOZA.Domain.Entities.Class

@{
    ViewBag.Title = "Chi tiết lớp học";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Teacher")">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("ClassList", "Teacher")">Danh sách lớp</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ClassName</li>
        </ol>
    </nav>
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">Quản lý bài tập</h5>
            <p class="card-text">Xem danh sách các bài tập đã giao và tiến độ làm bài của học sinh.</p>

            <a href="@Url.Action("ClassAssignmentsList", "Teacher", new { classId = Model.Id })"
               class="btn btn-primary">
                <i class="fa-solid fa-chart-pie me-2"></i>Xem tiến độ & Điểm số
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h2 class="fw-bold text-primary mb-1">@Model.ClassName</h2>
                    <p class="text-muted mb-0">Ngày tạo: @Model.CreatedAt.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="col-md-4 text-end">
                    <div class="p-3 bg-light rounded-3 d-inline-block text-center">
                        <small class="text-muted d-block">Mã tham gia lớp</small>
                        <span class="fs-3 fw-bold text-success">@Model.JoinCode</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0">
                <i class="fa-solid fa-users me-2"></i>Danh sách học sinh (@Model.ClassStudents.Count)
            </h5>
            <a href="@Url.Action("ExportStudents", "Teacher", new { classId = Model.Id })" class="btn btn-sm btn-success">
                <i class="fa-solid fa-file-excel me-1"></i> Xuất Excel
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Họ và tên</th>
                            <th>Email</th>
                            <th>Ngày tham gia</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ClassStudents.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    chưa có học sinh nào tham gia lớp này.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int index = 1;
                            // Duyệt qua danh sách ClassStudents để lấy thông tin User (Học sinh)
                            foreach (var item in Model.ClassStudents)
                            {
                                <tr>
                                    <td class="ps-4">@index</td>
                                    <td class="fw-bold">@item.Student.FullName</td>
                                    <td>@item.Student.Email</td>
                                    <td>@item.JoinedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger" title="Xóa khỏi lớp">
                                            <i class="fa-solid fa-user-xmark"></i>
                                        </button>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>