@{
    ViewBag.Title = "Dashboard Giáo Viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Tổng quan</h2>
        <a href="@Url.Action("CreateClass", "Teacher")" class="btn btn-warning text-white fw-bold rounded-pill px-4">
            <i class="fa-solid fa-plus me-2"></i>Tạo lớp ngay
        </a>
        <a href="@Url.Action("AssignExam", "Teacher")" class="btn btn-warning text-white fw-bold rounded-pill px-4">
            <i class="fa-solid fa-plus me-2"></i>Tạo bài tập ngay
        </a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="background-color: #fff3e6;">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="fs-1 text-warning me-3"><i class="fa-solid fa-chalkboard-user"></i></div>
                    <div>
                        <h3 class="fw-bold mb-0">@ViewBag.ClassCount</h3>
                        <p class="text-muted mb-0">Lớp học đang quản lý</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="background-color: #e6f7ff;">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="fs-1 text-primary me-3"><i class="fa-solid fa-file-signature"></i></div>
                    <div>
                        <h3 class="fw-bold mb-0">@ViewBag.SubmissionCount</h3>
                        <p class="text-muted mb-0">Bài tập đã chấm</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-3">Chức năng quản lý</h4>
    <div class="row g-3">
        <div class="col-md-3">
            <a href="@Url.Action("ClassList", "Teacher")" class="card text-decoration-none shadow-sm hover-card border-0">
                <div class="card-body text-center p-4">
                    <i class="fa-solid fa-users-rectangle fs-2 text-warning mb-3"></i>
                    <h5 class="text-dark fw-bold">Danh sách lớp</h5>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="@Url.Action("CreateExam", "Exam")" class="card text-decoration-none shadow-sm hover-card border-0">
                <div class="card-body text-center p-4">
                    <i class="fa-solid fa-file-circle-plus fs-2 text-warning mb-3"></i>
                    <!-- somewhere in the teacher dashboard -->
                    <h5 class="text-dark fw-bold">Tạo Đề Thi</h5>
                </div>
            </a>
        </div>
    </div>
</div>