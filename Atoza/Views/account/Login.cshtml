@{
    Layout = null;
    ViewBag.Title = "Đăng Nhập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — Atoza</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            min-height: 100vh;
            background: #f5f5f7;
            display: flex;
            flex-direction: column;
            font-family: 'Inter', sans-serif;
        }

        .auth-page {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        /* Top brand bar */
        .auth-topbar {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 2rem;
            position: fixed;
            top: 0; left: 0;
            background: rgba(245,245,247,0.85);
            backdrop-filter: blur(10px);
            z-index: 10;
            border-bottom: 1px solid rgba(0,0,0,0.06);
        }

        .auth-brand {
            font-weight: 800;
            font-size: 1.2rem;
            background: linear-gradient(135deg, #ff6a00, #ee0979);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
        }

        .auth-topbar-link {
            font-size: 0.85rem;
            color: #6b7280;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .auth-topbar-link span {
            color: #ff6a00;
            font-weight: 600;
        }

        .auth-topbar-link:hover { color: #374151; }

        /* Main card */
        .auth-box {
            background: #fff;
            border-radius: 20px;
            padding: 2.5rem 2.25rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 20px 60px -10px rgba(0,0,0,0.1);
            border: 1px solid rgba(0,0,0,0.06);
            margin-top: 1rem;
        }

        .auth-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #111827;
            margin-bottom: 0.35rem;
            letter-spacing: -0.02em;
        }

        .auth-subtitle {
            font-size: 0.875rem;
            color: #6b7280;
            margin-bottom: 1.75rem;
        }

        /* Inputs */
        .field-wrap {
            position: relative;
            margin-bottom: 1rem;
        }

        .field-label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.4rem;
            letter-spacing: 0.01em;
        }

        .field-input {
            width: 100%;
            height: 46px;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            padding: 0 1rem 0 2.75rem;
            font-size: 0.9rem;
            color: #111827;
            background: #fff;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
            font-family: 'Inter', sans-serif;
        }

        .field-input:focus {
            border-color: #ff6a00;
            box-shadow: 0 0 0 3px rgba(255,106,0,0.1);
        }

        .field-icon {
            position: absolute;
            left: 0.875rem;
            bottom: 0;
            height: 46px;
            display: flex;
            align-items: center;
            color: #9ca3af;
            font-size: 0.85rem;
            pointer-events: none;
        }

        /* Password toggle */
        .field-input.has-toggle { padding-right: 2.75rem; }

        .toggle-btn {
            position: absolute;
            right: 0;
            bottom: 0;
            height: 46px;
            width: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #9ca3af;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 0.85rem;
            transition: color 0.2s;
        }

        .toggle-btn:hover { color: #374151; }

        /* Remember + forgot */
        .auth-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }

        .check-label {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 0.85rem;
            color: #6b7280;
            cursor: pointer;
            user-select: none;
        }

        .check-label input[type="checkbox"] {
            width: 16px; height: 16px;
            accent-color: #ff6a00;
            cursor: pointer;
        }

        .forgot-link {
            font-size: 0.85rem;
            font-weight: 600;
            color: #ff6a00;
            text-decoration: none;
        }

        .forgot-link:hover { text-decoration: underline; }

        /* Submit button */
        .btn-submit {
            width: 100%;
            height: 46px;
            background: linear-gradient(135deg, #ff6a00, #ee0979);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
            box-shadow: 0 4px 14px rgba(255,106,0,0.35);
            font-family: 'Inter', sans-serif;
        }

        .btn-submit:hover {
            opacity: 0.93;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(255,106,0,0.4);
        }

        .btn-submit:active { transform: translateY(0); }

        .btn-google {
            width: 100%;
            height: 46px;
            background: #fff;
            color: #374151;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
            font-family: 'Inter', sans-serif;
        }

        .btn-google:hover {
            border-color: #d1d5db;
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
            transform: translateY(-1px);
        }

        .btn-google i { color: #ea4335; }

        /* Divider */
        .auth-divider {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 1.5rem 0;
            color: #d1d5db;
            font-size: 0.8rem;
        }

        .auth-divider::before,
        .auth-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f3f4f6;
        }

        /* Bottom link */
        .auth-bottom {
            text-align: center;
            font-size: 0.875rem;
            color: #6b7280;
            margin-top: 1.5rem;
        }

        .auth-bottom a {
            color: #ff6a00;
            font-weight: 600;
            text-decoration: none;
        }

        .auth-bottom a:hover { text-decoration: underline; }

        /* Error */
        .auth-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            border-radius: 10px;
            padding: 0.7rem 1rem;
            font-size: 0.85rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .auth-success {
            background: #ecfdf5;
            border: 1px solid #a7f3d0;
            color: #047857;
            border-radius: 10px;
            padding: 0.7rem 1rem;
            font-size: 0.85rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Footer note */
        .auth-footer {
            text-align: center;
            font-size: 0.78rem;
            color: #9ca3af;
            margin-top: 1.5rem;
            padding-bottom: 1rem;
        }

        .auth-footer a {
            color: #6b7280;
            text-decoration: none;
        }

        .auth-footer a:hover { color: #374151; }
    </style>
</head>
<body>

<!-- Top bar -->
<div class="auth-topbar">
    <a href="@Url.Action("Index", "Home")" class="auth-brand">
        <i class="fa-solid fa-paper-plane me-1"></i> Atoza
    </a>
    <a href="@Url.Action("Register", "Account")" class="auth-topbar-link">
        Chưa có tài khoản? <span>Đăng ký</span>
    </a>
</div>

<!-- Main -->
<div class="auth-page" style="padding-top: 5rem;">

    <div class="auth-box">

        <!-- Header -->
        <h1 class="auth-title">Chào mừng trở lại</h1>
        <p class="auth-subtitle">Đăng nhập để tiếp tục sử dụng Atoza</p>

        @if (TempData["AuthError"] != null)
        {
            <div class="auth-error">
                <i class="fa-solid fa-circle-exclamation"></i>
                @TempData["AuthError"]
            </div>
        }

        @if (TempData["AuthMessage"] != null)
        {
            <div class="auth-success">
                <i class="fa-solid fa-circle-check"></i>
                @TempData["AuthMessage"]
            </div>
        }

        <!-- Form -->
        <form action="@Url.Action("Login", "Account")" method="post" autocomplete="on">
            @Html.AntiForgeryToken()

            <div class="field-wrap">
                <label class="field-label" for="username">Tên đăng nhập hoặc email</label>
                <div style="position:relative;">
                    <i class="fa-solid fa-user field-icon"></i>
                    <input id="username" type="text" name="username" class="field-input"
                           placeholder="Nhập tên đăng nhập hoặc email" required autocomplete="username"
                           value="@(Context.Request.Cookies["RememberMe_Username"] ?? "")" />
                </div>
            </div>

            <div class="field-wrap" style="margin-bottom:0.75rem;">
                <label class="field-label" for="passwordInput">Mật khẩu</label>
                <div style="position:relative;">
                    <i class="fa-solid fa-lock field-icon"></i>
                    <input id="passwordInput" type="password" name="password"
                           class="field-input has-toggle"
                           placeholder="Nhập mật khẩu" required autocomplete="current-password" />
                    <button type="button" class="toggle-btn" id="togglePassword" tabindex="-1">
                        <i class="fa-solid fa-eye" id="eyeIcon"></i>
                    </button>
                </div>
            </div>

            <div class="auth-row">
                <label class="check-label">
                    <input type="checkbox" name="rememberMe" value="true" id="chkRemember">
                    Ghi nhớ đăng nhập
                </label>
                <a href="@Url.Action("ForgotPassword", "Account")" class="forgot-link">Quên mật khẩu?</a>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="auth-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    @ViewBag.Error
                </div>
            }

            <button type="submit" class="btn-submit">
                Đăng nhập
            </button>
        </form>

        <div class="auth-divider">hoặc</div>

        <form action="@Url.Action("ExternalLogin", "Account")" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="provider" value="Google" />
            <button type="submit" class="btn-google">
                <i class="fa-brands fa-google me-2"></i>Đăng nhập với Google
            </button>
        </form>

        <div class="auth-bottom">
            Chưa có tài khoản?
            <a href="@Url.Action("Register", "Account")">Đăng ký miễn phí</a>
        </div>
    </div>

    <!-- Footer -->
    <div class="auth-footer">
        <a href="@Url.Action("Index", "Home")">
            <i class="fa-solid fa-arrow-left me-1"></i>Về trang chủ
        </a>
        &nbsp;&bull;&nbsp; &copy; 2024 Atoza
    </div>

</div>

<script>
    const toggleBtn = document.getElementById('togglePassword');
    const pwInput = document.getElementById('passwordInput');
    const eyeIcon = document.getElementById('eyeIcon');

    toggleBtn.addEventListener('click', () => {
        const isPassword = pwInput.type === 'password';
        pwInput.type = isPassword ? 'text' : 'password';
        eyeIcon.className = isPassword ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
    });
</script>
</body>
</html>
