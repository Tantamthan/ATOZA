@{
    Layout = null; // Tắt Layout chính để ẩn Header/Footer
    ViewBag.Title = "Đăng Nhập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Atoza Clone</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            background-color: #f8f9fa; /* Thêm màu nền nhẹ cho đẹp */
            height: 100vh;
            display: flex;
            align-items: center; /* Căn giữa theo chiều dọc */
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg border-0 rounded-3">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <i class="fa-solid fa-paper-plane fa-3x mb-3" style="color: #ff6a00;"></i>
                            <h3 class="fw-bold">Đăng Nhập</h3>
                            <p class="text-muted small">Chào mừng bạn quay trở lại!</p>
                        </div>

                        <form action="@Url.Action("Login", "Account")" method="post">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label class="form-label fw-bold">Tên đăng nhập</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fa-solid fa-user"></i></span>
                                    <input type="text" name="username" class="form-control" placeholder="Nhập username" required
                                           value="@(Context.Request.Cookies["RememberMe_Username"] ?? "")" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Mật khẩu</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fa-solid fa-lock"></i></span>
                                    <input type="password" name="password" id="passwordInput" class="form-control" placeholder="Nhập mật khẩu" required />
                                    <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                                        <i class="fa-solid fa-eye"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" name="rememberMe" value="true" id="chkRemember">
                                <label class="form-check-label text-muted" for="chkRemember">Ghi nhớ đăng nhập</label>
                            </div>

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger text-center">
                                    <i class="fa-solid fa-circle-exclamation me-2"></i> @ViewBag.Error
                                </div>
                            }

                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn text-white fw-bold py-2" style="background-color: #ff6a00;">Đăng Nhập</button>
                            </div>
                        </form>

                        <hr class="my-4">

                        <div class="text-center">
                            <span class="text-muted">Chưa có tài khoản?</span>
                            <a href="@Url.Action("Register", "Account")" class="text-decoration-none fw-bold" style="color: #ff6a00;">Đăng ký miễn phí</a>
                            <br />
                            <a href="@Url.Action("Index", "Home")" class="text-muted small mt-2 d-inline-block"><i class="fa-solid fa-arrow-left"></i> Về trang chủ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const password = document.querySelector('#passwordInput');
        const icon = togglePassword.querySelector('i');

        togglePassword.addEventListener('click', function () {
            const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
            password.setAttribute('type', type);

            if (type === 'text') {
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        });
    </script>
</body>
</html>