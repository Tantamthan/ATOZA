@model ATOZA.Application.DTOs.RegisterDto
@* Lưu ý: Dùng RegisterViewModel nếu bạn đã tạo theo hướng dẫn trước, hoặc dùng ATOZA.Models.User nếu chưa sửa *@

@{
    Layout = null; // Tắt Layout chính
    ViewBag.Title = "Đăng Ký Tài Khoản";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Atoza Clone</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 40px 0; /* Thêm padding vì form đăng ký dài */
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-lg border-0 rounded-3">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <i class="fa-solid fa-user-plus fa-3x mb-3" style="color: #ff6a00;"></i>
                            <h3 class="fw-bold" style="color: #ff6a00;">Đăng Ký Thành Viên</h3>
                        </div>

                        @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                            <div class="mb-3">
                                <label class="form-label fw-bold">Họ và tên</label>
                                @Html.EditorFor(model => model.FullName, new { htmlAttributes = new { @class = "form-control", placeholder = "Nhập họ tên" } })
                                @Html.ValidationMessageFor(model => model.FullName, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Email</label>
                                @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", type = "email", placeholder = "email@example.com" } })
                                @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Bạn là?</label>
                                @Html.DropDownListFor(model => model.Role, new List<SelectListItem>
                                {
                                    new SelectListItem { Text = "Học sinh (Student)", Value = "Student" },
                                    new SelectListItem { Text = "Giáo viên (Teacher)", Value = "Teacher" }
                                }, "--- Chọn vai trò ---", new { @class = "form-select" })
                                @Html.ValidationMessageFor(model => model.Role, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Tên đăng nhập</label>
                                @Html.EditorFor(model => model.UserName, new { htmlAttributes = new { @class = "form-control", placeholder = "Username" } })
                                @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "text-danger" })
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Mật khẩu</label>
                                    @Html.PasswordFor(model => model.Password, new { @class = "form-control", placeholder = "Nhập mật khẩu" })
                                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                                    @Html.PasswordFor(model => model.ConfirmPassword, new { @class = "form-control", placeholder = "Nhập lại mật khẩu" })
                                    @Html.ValidationMessageFor(model => model.ConfirmPassword, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger text-center">@ViewBag.Error</div>
                            }

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn text-white fw-bold py-2" style="background-color: #ff6a00;">Đăng Ký Ngay</button>
                            </div>
                        }

                        <hr class="my-4">

                        <div class="text-center">
                            <span class="text-muted">Đã có tài khoản?</span>
                            <a href="@Url.Action("Login", "Account")" class="text-decoration-none fw-bold" style="color: #ff6a00;">Đăng nhập</a>
                            <br />
                            <a href="@Url.Action("Index", "Home")" class="text-muted small mt-2 d-inline-block"><i class="fa-solid fa-arrow-left"></i> Về trang chủ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>