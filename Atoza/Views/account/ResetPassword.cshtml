@model ATOZA.Application.DTOs.ResetPasswordDto

@{
    Layout = null;
    ViewBag.Title = "Đặt lại mật khẩu";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — Atoza</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            min-height: 100vh;
            background: #f5f5f7;
            display: flex;
            flex-direction: column;
            font-family: 'Inter', sans-serif;
        }

        .auth-topbar {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 2rem;
            position: fixed;
            top: 0; left: 0;
            background: rgba(245,245,247,0.85);
            backdrop-filter: blur(10px);
            z-index: 10;
            border-bottom: 1px solid rgba(0,0,0,0.06);
        }

        .auth-brand {
            font-weight: 800;
            font-size: 1.2rem;
            background: linear-gradient(135deg, #ff6a00, #ee0979);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
        }

        .auth-topbar-link {
            font-size: 0.85rem;
            color: #6b7280;
            text-decoration: none;
            font-weight: 500;
        }

        .auth-topbar-link span { color: #ff6a00; font-weight: 600; }

        .auth-page {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 5rem 1rem 2rem;
        }

        .auth-box {
            background: #fff;
            border-radius: 20px;
            padding: 2.5rem 2.25rem;
            width: 100%;
            max-width: 430px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 20px 60px -10px rgba(0,0,0,0.1);
            border: 1px solid rgba(0,0,0,0.06);
        }

        .auth-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #111827;
            margin-bottom: 0.35rem;
        }

        .auth-subtitle {
            font-size: 0.875rem;
            color: #6b7280;
            margin-bottom: 1.75rem;
        }

        .field-wrap { position: relative; margin-bottom: 1rem; }

        .field-label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.4rem;
        }

        .field-input {
            width: 100%;
            height: 46px;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            padding: 0 1rem 0 2.75rem;
            font-size: 0.9rem;
            color: #111827;
            background: #fff;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
            font-family: 'Inter', sans-serif;
        }

        .field-input.has-toggle { padding-right: 2.75rem; }

        .field-input:focus {
            border-color: #ff6a00;
            box-shadow: 0 0 0 3px rgba(255,106,0,0.1);
        }

        .field-icon {
            position: absolute;
            left: 0.875rem;
            bottom: 0;
            height: 46px;
            display: flex;
            align-items: center;
            color: #9ca3af;
            font-size: 0.85rem;
            pointer-events: none;
        }

        .toggle-btn {
            position: absolute;
            right: 0;
            bottom: 0;
            height: 46px;
            width: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #9ca3af;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 0.85rem;
        }

        .btn-submit {
            width: 100%;
            height: 46px;
            background: linear-gradient(135deg, #ff6a00, #ee0979);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(255,106,0,0.35);
            font-family: 'Inter', sans-serif;
        }

        .btn-submit:hover {
            opacity: 0.93;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(255,106,0,0.4);
        }

        .auth-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            border-radius: 10px;
            padding: 0.7rem 1rem;
            font-size: 0.85rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .validation-msg {
            font-size: 0.78rem;
            color: #dc2626;
            margin-top: 0.3rem;
        }

        .auth-bottom {
            text-align: center;
            font-size: 0.875rem;
            color: #6b7280;
            margin-top: 1.5rem;
            padding-top: 1.25rem;
            border-top: 1px solid #f3f4f6;
        }

        .auth-bottom a {
            color: #ff6a00;
            font-weight: 600;
            text-decoration: none;
        }
    </style>
</head>
<body>
<div class="auth-topbar">
    <a href="@Url.Action("Index", "Home")" class="auth-brand">
        <i class="fa-solid fa-paper-plane me-1"></i> Atoza
    </a>
    <a href="@Url.Action("Login", "Account")" class="auth-topbar-link">
        Quay lại <span>đăng nhập</span>
    </a>
</div>

<div class="auth-page">
    <div class="auth-box">
        <h1 class="auth-title">Đặt lại mật khẩu</h1>
        <p class="auth-subtitle">Tạo mật khẩu mới cho tài khoản của bạn.</p>

        @if (ViewBag.Error != null)
        {
            <div class="auth-error">
                <i class="fa-solid fa-circle-exclamation"></i>
                @ViewBag.Error
            </div>
        }

        @if (ViewData.ModelState.Values.Any(v => v.Errors.Any()))
        {
            <div class="auth-error">
                <i class="fa-solid fa-circle-exclamation"></i>
                Vui lòng kiểm tra lại mật khẩu mới.
            </div>
        }

        @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { autocomplete = "on" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Token)

            <div class="field-wrap">
                <label class="field-label" for="Password">Mật khẩu mới</label>
                <div style="position:relative;">
                    <i class="fa-solid fa-lock field-icon"></i>
                    @Html.PasswordFor(m => m.Password, new { @class = "field-input has-toggle", id = "Password", placeholder = "Tối thiểu 6 ký tự", autocomplete = "new-password" })
                    <button type="button" class="toggle-btn" data-target="Password" tabindex="-1">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                </div>
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "validation-msg" })
            </div>

            <div class="field-wrap">
                <label class="field-label" for="ConfirmPassword">Xác nhận mật khẩu</label>
                <div style="position:relative;">
                    <i class="fa-solid fa-lock field-icon"></i>
                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "field-input has-toggle", id = "ConfirmPassword", placeholder = "Nhập lại mật khẩu", autocomplete = "new-password" })
                    <button type="button" class="toggle-btn" data-target="ConfirmPassword" tabindex="-1">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                </div>
                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "validation-msg" })
            </div>

            <button type="submit" class="btn-submit">Cập nhật mật khẩu</button>
        }

        <div class="auth-bottom">
            Quay lại <a href="@Url.Action("Login", "Account")">đăng nhập</a>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.toggle-btn').forEach(button => {
        button.addEventListener('click', () => {
            const input = document.getElementById(button.dataset.target);
            const icon = button.querySelector('i');
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            icon.className = isPassword ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
        });
    });
</script>
</body>
</html>
