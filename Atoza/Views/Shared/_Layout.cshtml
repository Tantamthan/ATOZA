<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Atoza</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    @{
        string homeController = "Home";
        var currentRole = Context.Session.GetString("Role")
            ?? User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        var currentFullName = Context.Session.GetString("FullName")
            ?? User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
            ?? User.Identity?.Name;

        if (currentRole == "Teacher") { homeController = "Teacher"; }
        else if (currentRole == "Student") { homeController = "Student"; }
        else if (currentRole == "Admin") { homeController = "Admin"; }
    }

    <header>
        <nav class="navbar navbar-expand-lg fixed-top">
            <div class="container">
                <a class="navbar-brand" href="@Url.Action("Index", homeController)">
                    <i class="fa-solid fa-paper-plane me-1"></i> Atoza
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-3">
                        <li class="nav-item"><a class="nav-link" href="#">Giới thiệu</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Tính năng</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Hướng dẫn</a></li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @if (currentFullName != null)
                        {
                            <div class="dropdown">
                                <a class="btn btn-outline-primary rounded-pill px-4 d-flex align-items-center gap-2"
                                   href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="d-inline-flex align-items-center justify-content-center bg-gradient rounded-circle text-white"
                                          style="width:26px;height:26px;background:linear-gradient(135deg,#ff6a00,#ee0979)!important;font-size:0.7rem;font-weight:700;">
                                        @(currentFullName.Length > 0 ? currentFullName[0].ToString().ToUpper() : "U")
                                    </span>
                                    <span style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@currentFullName</span>
                                    <i class="fa-solid fa-chevron-down" style="font-size:0.65rem;opacity:0.6;"></i>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <div class="px-3 py-2 mb-1">
                                            <div class="fw-700 text-dark" style="font-size:0.9rem;font-weight:700;">@currentFullName</div>
                                            <div class="text-muted" style="font-size:0.75rem;">
                                                @if (currentRole == "Teacher") { <span>Giáo viên</span> }
                                                else if (currentRole == "Student") { <span>Học sinh</span> }
                                                else if (currentRole == "Admin") { <span>Quản trị viên</span> }
                                            </div>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>

                                    @if (currentRole == "Teacher")
                                    {
                                        <li><a class="dropdown-item" href="@Url.Action("Index", "Teacher")">
                                            <i class="fa-solid fa-gauge-high me-2 text-primary"></i>Dashboard</a></li>
                                    }
                                    else if (currentRole == "Admin")
                                    {
                                        <li><a class="dropdown-item" href="@Url.Action("Index", "Admin")">
                                            <i class="fa-solid fa-shield-halved me-2 text-primary"></i>Admin Panel</a></li>
                                        <li><a class="dropdown-item" href="@Url.Action("UserList", "Admin")">
                                            <i class="fa-solid fa-users-gear me-2 text-primary"></i>Tài khoản</a></li>
                                    }
                                    else if (currentRole == "Student")
                                    {
                                        <li><a class="dropdown-item" href="@Url.Action("Index", "Student")">
                                            <i class="fa-solid fa-book-open me-2 text-primary"></i>Lớp học của tôi</a></li>
                                    }

                                    <li><a class="dropdown-item" href="#">
                                        <i class="fa-solid fa-id-card me-2 text-muted"></i>Thông tin cá nhân</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")">
                                            <i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary rounded-pill px-4">Đăng nhập</a>
                            <a href="@Url.Action("Register", "Account")" class="btn btn-orange rounded-pill px-4">Đăng ký</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div style="padding-top: 70px;">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer pt-5 pb-4 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 mb-2">
                    <div class="footer-brand mb-2">
                        <i class="fa-solid fa-paper-plane me-1"></i> Atoza
                    </div>
                    <p class="text-white-50 small mb-3" style="line-height:1.7;">
                        Hệ thống tạo đề thi và chấm bài tự động, giúp giáo viên tiết kiệm thời gian và nâng cao chất lượng giảng dạy.
                    </p>
                    <div class="d-flex gap-2">
                        <a href="#" class="footer-social"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="footer-social"><i class="fab fa-youtube"></i></a>
                        <a href="#" class="footer-social"><i class="fab fa-tiktok"></i></a>
                    </div>
                </div>

                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-700 mb-3" style="font-size:0.85rem;letter-spacing:0.05em;text-transform:uppercase;">Sản phẩm</h6>
                    <a href="#" class="footer-link">Tạo đề thi</a>
                    <a href="#" class="footer-link">Chấm bài tự động</a>
                    <a href="#" class="footer-link">Quản lý lớp học</a>
                    <a href="#" class="footer-link">Thống kê điểm</a>
                </div>

                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-700 mb-3" style="font-size:0.85rem;letter-spacing:0.05em;text-transform:uppercase;">Công ty</h6>
                    <a href="#" class="footer-link">Giới thiệu</a>
                    <a href="#" class="footer-link">Tuyển dụng</a>
                    <a href="#" class="footer-link">Điều khoản</a>
                    <a href="#" class="footer-link">Chính sách bảo mật</a>
                </div>

                <div class="col-lg-4">
                    <h6 class="text-white fw-700 mb-3" style="font-size:0.85rem;letter-spacing:0.05em;text-transform:uppercase;">Liên hệ</h6>
                    <p class="small text-white-50 mb-2"><i class="fa-solid fa-phone me-2 text-warning"></i> 0909.999.999</p>
                    <p class="small text-white-50 mb-2"><i class="fa-solid fa-envelope me-2 text-warning"></i> contact@atoza.vn</p>
                    <p class="small text-white-50 mb-0"><i class="fa-solid fa-location-dot me-2 text-warning"></i> TP. Hồ Chí Minh, Việt Nam</p>
                </div>
            </div>

            <hr class="border-secondary my-4" style="opacity:0.15;">

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <p class="small text-white-50 mb-0">&copy; 2024 Atoza — All rights reserved</p>
                <p class="small text-white-50 mb-0">Made with <i class="fa-solid fa-heart text-danger mx-1"></i> in Vietnam</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
