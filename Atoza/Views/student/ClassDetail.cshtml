@model IEnumerable<ATOZA.Domain.Entities.ClassAssignment>

@{
    ViewBag.Title = ViewBag.ClassName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Student")">Lớp học của tôi</a></li>
            <li class="breadcrumb-item active" aria-current="page">@ViewBag.ClassName</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary">@ViewBag.ClassName</h3>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded">
            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" width="100" style="opacity:0.5" />
            <p class="text-muted mt-3">Chưa có bài tập nào được giao cho lớp này.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                // Logic kiểm tra thời gian
                var now = DateTime.Now;
                bool isUpcoming = now < item.AvailableFrom;
                bool isExpired = now > item.DueDate;
                bool canDo = !isUpcoming && !isExpired;

                <div class="col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <h5 class="card-title fw-bold mb-0 text-dark">@item.Exam.Title</h5>

                                @if (isExpired)
                                {
                                    <span class="badge bg-danger">Hết hạn</span>
                                }
                                else if (isUpcoming)
                                {
                                    <span class="badge bg-warning text-dark">Sắp mở</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Đang mở</span>
                                }
                            </div>

                            <p class="text-muted small mb-3">
                                <i class="fa-regular fa-clock me-1"></i> Thời gian làm: @item.Exam.DurationMinutes phút <br />
                                <i class="fa-regular fa-calendar-check me-1"></i> Hạn nộp: @item.DueDate.ToString("dd/MM/yyyy HH:mm")
                            </p>

                            @if (canDo)
                            {
                               <a href="@Url.Action("Index", "Exam", new { id = item.ExamId })" class="btn btn-primary">
                                   Làm bài ngay
                               </a>
                            }
                            else if (isUpcoming)
                            {
                                <button class="btn btn-secondary w-100" disabled>
                                    Mở lúc: @item.AvailableFrom.ToString("dd/MM HH:mm")
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100" disabled>Không thể làm bài</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>